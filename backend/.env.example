# Core runtime
PORT=8080
MONGODB_URI=
JWT_SECRET=

# Frontend origins
FRONTEND_URL=https://your-frontend-domain.example
# Optional: comma-separated additional allowed origins
# FRONTEND_URLS=https://preview-1.example,https://preview-2.example

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-frontend-domain.example/api/google/callback

# Optional app URL fallback for emails
# APP_URL=https://your-frontend-domain.example

# Optional feature flags / integrations
# ENCRYPTION_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# MAILJET_API_KEY=
# MAILJET_API_SECRET=
# MAILJET_FROM_EMAIL=noreply@lifeos.app
# MAILJET_FROM_NAME=LifeOS

# Backblaze B2 (only for Vault/Photo uploads)
# B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET_NAME=
# B2_PUBLIC_URL=https://f005.backblazeb2.com/file/your-bucket
# B2_REGION=us-east-005
